# ── 경로 설정 ─────────────────────────────────────────────
# 프로젝트 루트 기준 상대 경로

# PPTX 원본 파일 폴더
PPTX_DIR=./pptx

# 출력 폴더 (하위에 YYYYMMDD-HH24MISS 타임스탬프 폴더 자동 생성)
OUTPUT_DIR=./output

# 병합 출력 파일명 (merge_pptx.py, OUTPUT_DIR/timestamp/ 하위에 저장)
MERGE_OUTPUT=III.기술부문.pptx

# ── 페이지 번호 스타일 (add_page_numbers.py) ──────────────

# 폰트 크기 (pt)
PAGE_NUM_FONT_SIZE=8

# 글자 색상 (RGB hex)
PAGE_NUM_COLOR=606060

# 우측 여백 (inch)
PAGE_NUM_MARGIN_RIGHT=0.3

# 하단 여백 (inch)
PAGE_NUM_MARGIN_BOTTOM=0.2

# 텍스트 박스 너비 (inch)
PAGE_NUM_WIDTH=1.0
